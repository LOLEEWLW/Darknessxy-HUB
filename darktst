-- SILENT AIM HOOK (FireServer/InvokeServer)
-- ==========================================
local oldNamecall
local metatable = getrawmetatable(game)
if metatable then
    setreadonly(metatable, false)
    oldNamecall = metatable.__namecall
    metatable.__namecall = newcclosure(function(self, ...)
        local args = {...}
        local method = getnamecallmethod()

        if silentEnabled and silentTargetPos then
            if method == "FireServer" or method == "InvokeServer" then
                for i, arg in ipairs(args) do
                    if typeof(arg) == "Vector3" then
                        args[i] = silentTargetPos
                    elseif type(arg) == "table" and arg.X and arg.Y and arg.Z then
                        args[i] = silentTargetPos
                    end
                end
                return oldNamecall(self, unpack(args))
            end
        end

        return oldNamecall(self, ...)
    end)
    setreadonly(metatable, true)
else
    warn("getrawmetatable falhou - Silent Aim pode não funcionar.")
end

