-- Função para obter HWID (compatível com vários exploits)
local function getHWID()
    local success, result = pcall(function()
        if syn and syn.crypt and syn.crypt.custom and syn.crypt.custom.hash then
            return syn.crypt.custom.hash("DARK_PREMIUM_HWID_SALT")
        end
    end)
    if success and result then return result end

    success, result = pcall(function()
        if getgenv().request or request then
            local http = getgenv().request or request
            return game:GetService("RbxAnalyticsService"):GetClientId()
        end
    end)
    if success and result then return result end

    -- Fallback
    return game:GetService("RbxAnalyticsService"):GetClientId() .. "-" .. game.PlaceId
end

-- Função que valida key + hwid no Google Sheets
local function validarKeyNoServidor(key, hwid)
    local url = API_URL .. "?action=validar&key=" .. tostring(key)
    if hwid and hwid ~= "" then
        url = url .. "&hwid=" .. tostring(hwid)
    end
    
    local success, response = pcall(function()
        return syn.request({Url = url, Method = "GET"})
    end)
    
    if not success then
        success, response = pcall(function()
            return (getgenv().request or request)({Url = url, Method = "GET"})
        end)
    end
    
    if not success then
        return false, "Erro ao conectar com o servidor"
    end
    
    local success2, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(response.Body)
    end)
    
    if not success2 then
        return false, "Erro ao processar resposta"
    end
    
    return data.valida, data.motivo
end

