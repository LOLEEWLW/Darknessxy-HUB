-- Variáveis para arraste
local dragging = false
local dragStartMouse = nil
local dragStartPosition = nil

ToggleButton.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStartMouse = Vector2.new(input.Position.X, input.Position.Y)
        dragStartPosition = ToggleButton.Position
        -- Previne que o clique seja processado como click se houve arraste
        ToggleButton.Dragging = true
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStartMouse
        -- Converte delta para escala
        local screenSize = ScreenGui.AbsoluteSize
        local deltaScaleX = delta.X / screenSize.X
        local deltaScaleY = delta.Y / screenSize.Y

        local newX = math.clamp(dragStartPosition.X.Scale + deltaScaleX, 0, 1 - ToggleButton.Size.X.Scale)
        local newY = math.clamp(dragStartPosition.Y.Scale + deltaScaleY, 0, 1 - ToggleButton.Size.Y.Scale)

        ToggleButton.Position = UDim2.new(newX, 0, newY, 0)
    end
end)

ToggleButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
        dragging = false
        -- Se o mouse não se moveu muito, considera como clique
        local dist = (Vector2.new(input.Position.X, input.Position.Y) - dragStartMouse).Magnitude
        if dist < 10 then
            -- Ação de clique: alternar visibilidade
            uiVisible = not uiVisible
            MainFrame.Visible = uiVisible
        end
    end
end)

